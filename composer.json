{
  "name": "kenzal/benchmark",
  "description": "A basic expression benchmarking utility",
  "keywords": [
    "benchmark",
    "php",
    "dev"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "J. Kenzal Hunter, Sr.",
      "email": "kenzal@ksavalon.net"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "autoload": {
    "psr-4": {
      "Kenzal\\Utility\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kenzal\\Utility\\Tests\\": "tests/"
    }
  },
  "require-dev": {    "laravel/pint": "*",
    "pestphp/pest": "*",
    "phpstan/phpstan": "*",
    "psy/psysh": "*",
    "rector/rector": "*"
  },
  "scripts": {
    "fix": [
      "@refactor",
      "@lint"
    ],
    "herd:test": [
      "@herd:test:unit",
      "@test:types"
    ],
    "herd:test:unit": "herd coverage ./vendor/bin/pest --coverage --min=100",
    "lint": "pint",
    "refactor": "rector",
    "repl": "psysh",
    "test": [
      "@test:unit",
      "@test:types"
    ],
    "test:lint": "pint --test",
    "test:unit": "pest --coverage --min=100",
    "test:types": "phpstan",
    "test:refactor": "rector --dry-run"
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
